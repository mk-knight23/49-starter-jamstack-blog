{
  "name": "vue-ssg-editorial-blog",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:client\"",
    "dev:api": "tsx src/server/api/index.ts",
    "dev:client": "vite",
    "build": "vite-ssg build && tsx scripts/generate-seo.ts",
    "preview": "vite preview",
    "generate-seo": "tsx scripts/generate-seo.ts",
    "type-check": "vue-tsc --noEmit",
    "new-post": "bash .claude/scripts/new-post.sh",
    "init-db": "tsx scripts/init-db.ts",
    "seed-db": "tsx scripts/seed-db.ts"
  },
  "dependencies": {
    "@motionone/vue": "^10.16.4",
    "@types/markdown-it-highlightjs": "^3.3.4",
    "@vueuse/core": "^11.3.0",
    "@vueuse/head": "^2.0.0",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.6.2",
    "clsx": "^2.1.1",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "fuse.js": "^7.1.0",
    "gray-matter": "^4.0.3",
    "highlight.js": "^11.11.1",
    "jsonwebtoken": "^9.0.3",
    "lucide-vue-next": "^0.468.0",
    "markdown-it": "^14.1.1",
    "markdown-it-highlightjs": "^4.2.0",
    "pinia": "^2.3.0",
    "tailwind-merge": "^2.5.5",
    "vue": "^3.5.29",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^22.10.2",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vue/tsconfig": "^0.7.0",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.21.0",
    "typescript": "~5.6.2",
    "vite": "^6.0.5",
    "vite-plugin-static-copy": "^3.2.0",
    "vite-ssg": "^0.24.3",
    "vue-tsc": "^2.1.10"
  }
}
